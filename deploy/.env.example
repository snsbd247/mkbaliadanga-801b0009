# =============================================================================
# deploy/.env.example — copy to .env.production (install.sh auto-generates one)
# =============================================================================

# ---- Project / domain -------------------------------------------------------
PROJECT_NAME=mkbaliadanga
SERVER_IP=144.79.249.145
BASE_DOMAIN=mohammadkhani.com
ADMIN_EMAIL=ismailsagor162@gmail.com
ADMIN_PASSWORD=                   # first app login password, auto-generated if empty

APP_DOMAIN=mohammadkhani.com          # app runs on the main domain (not a subdomain)
SUPABASE_DOMAIN=supabase.mohammadkhani.com
COOLIFY_DOMAIN=coolify.mohammadkhani.com

# ---- GitHub (Coolify auto-deploy) ------------------------------------------
GIT_REPOSITORY=https://github.com/snsbd247/mkbaliadanga-801b0009.git
GIT_BRANCH=main

# ---- PostgreSQL -------------------------------------------------------------
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                # auto-generated if empty

# ---- Supabase secrets (auto-generated if empty) -----------------------------
JWT_SECRET=                       # >= 32 chars
ANON_KEY=                         # HS256 JWT (role=anon)
SERVICE_ROLE_KEY=                 # HS256 JWT (role=service_role)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=               # auto-generated if empty
SECRET_KEY_BASE=                  # realtime, auto-generated
REALTIME_DB_ENC_KEY=              # realtime DB encryption key, exactly 16 chars, auto-generated
VAULT_ENC_KEY=                    # storage/vault, auto-generated (32 chars)

# ---- Derived public endpoints ----------------------------------------------
SUPABASE_PUBLIC_URL=https://supabase.mohammadkhani.com
SITE_URL=https://mohammadkhani.com
API_EXTERNAL_URL=https://supabase.mohammadkhani.com
STUDIO_DEFAULT_ORGANIZATION="MK Baliadanga"
STUDIO_DEFAULT_PROJECT="MK Baliadanga"

# ---- Frontend build args (Vite) --------------------------------------------
VITE_SUPABASE_URL=https://supabase.mohammadkhani.com
VITE_SUPABASE_PUBLISHABLE_KEY=    # = ANON_KEY (filled by install.sh)
VITE_SUPABASE_ANON_KEY=           # = ANON_KEY (filled by install.sh)

# ---- SMTP (optional, for auth emails) --------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME="MK Baliadanga"
SMTP_ADMIN_EMAIL=ismailsagor162@gmail.com

# ---- Backups ----------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
