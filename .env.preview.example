# =====================================================================
# Lovable Preview environment (Supabase Cloud)
# The frontend reads ONLY these vars — no Supabase URL/key lives in code.
# Lovable auto-injects the real .env in Preview; this file documents it.
# =====================================================================
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<cloud-anon-key>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
