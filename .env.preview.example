# =====================================================================
# Lovable Preview environment
# The frontend reads ONLY these vars — no Supabase URL/key lives in code.
# Lovable auto-injects the real .env in Preview; this file documents it.
# =====================================================================
VITE_SUPABASE_URL="<lovable-preview-backend-url>"
VITE_SUPABASE_PUBLISHABLE_KEY="<lovable-preview-publishable-key>"
VITE_SUPABASE_PROJECT_ID="<lovable-preview-project-id>"
