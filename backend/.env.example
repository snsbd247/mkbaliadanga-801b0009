APP_NAME="MK Cooperative ERP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka
APP_URL=https://mohammadkhani.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (MySQL 8) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mk_erp
DB_USERNAME=mk_erp
DB_PASSWORD=

# --- Sanctum / CORS ---
# Token lifetime in minutes (default 7 days). Set null for non-expiring tokens.
SANCTUM_EXPIRATION=10080
SANCTUM_STATEFUL_DOMAINS=mohammadkhani.com,www.mohammadkhani.com
CORS_ALLOWED_ORIGINS=https://mohammadkhani.com,https://www.mohammadkhani.com

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=database

# ── Legacy data import (Supabase/PostgreSQL source) ──
# Used only by: php artisan migrate:legacy
PG_HOST=db.jcdonpeftfrnzblhtsqo.supabase.co
PG_PORT=5432
PG_DATABASE=postgres
PG_USERNAME=postgres
PG_PASSWORD=
PG_SSLMODE=require

# --- Admin bootstrap ---
# Default password used ONLY the first time the canonical admin accounts are
# created. Changing an existing password later is never reverted by update.sh.
DEFAULT_ADMIN_PASSWORD=Admin@123
