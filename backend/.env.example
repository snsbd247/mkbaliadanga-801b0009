APP_NAME="MK Baliadanga"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Dhaka
APP_LOCALE=bn

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mkbaliadanga
DB_USERNAME=mkb_user
DB_PASSWORD=change_me_strong

BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# MinIO / S3-compatible
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=mkb_minio
AWS_SECRET_ACCESS_KEY=change_me_minio
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=mkb-assets
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=https://files.example.com

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,mkbaliadanga.example.com
SESSION_DOMAIN=.example.com

# Initial admin (used by seeder)
ADMIN_EMAIL=admin@mkb.local
ADMIN_PASSWORD=ChangeMe!2025
ADMIN_NAME="System Admin"

# SMS
GREENWEB_SMS_TOKEN=
SMS_SENDER_ID=

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@mkb.local"
MAIL_FROM_NAME="${APP_NAME}"
