# Production environment template for Laravel API
# Copy to .env on the server and fill in real values.

APP_NAME="MK Baliadanga"
APP_ENV=production
APP_KEY=                                # php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.mohammadkhani.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mk_prod
DB_USERNAME=mk
DB_PASSWORD=

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sanctum / CORS — frontend origins that may call the API
SANCTUM_STATEFUL_DOMAINS=mohammadkhani.com,mk.syncsolutionbd.com,mkbaliadanga.lovable.app
CORS_ALLOWED_ORIGINS=https://mohammadkhani.com,https://mk.syncsolutionbd.com,https://mkbaliadanga.lovable.app

# SMS provider (configure your real gateway)
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@mohammadkhani.com"
MAIL_FROM_NAME="${APP_NAME}"

# Backups
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
