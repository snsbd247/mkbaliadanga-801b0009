    </tr>
    <tr>
      <td style="padding:4px 8px;vertical-align:top;width:38%;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">গ্রাম/মহল্লা/মোবাইল নং:</td>
      <td style="padding:4px 8px;vertical-align:top;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">— / 01700000000</td>
    </tr>
    <tr>
      <td style="padding:4px 8px;vertical-align:top;width:38%;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">পিতার/স্বামীর নাম:</td>
      <td style="padding:4px 8px;vertical-align:top;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">—</td>
    </tr>
    <tr>
      <td style="padding:4px 8px;vertical-align:top;width:38%;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">মৌজা / জমির পরিমান:</td>
      <td style="padding:4px 8px;vertical-align:top;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">N/A</td>
    </tr>
    <tr>
      <td style="padding:4px 8px;vertical-align:top;width:38%;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">জমির মালিক:</td>
      <td style="padding:4px 8px;vertical-align:top;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">N/A</td>
    </tr>
    <tr>
      <td style="padding:4px 8px;vertical-align:top;width:38%;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">মোট আদায়ের পরিমাণ:</td>
      <td style="padding:4px 8px;vertical-align:top;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">1,500.00 (এক হাজার পাঁচ শত টাকা)</td>
    </tr>
    <tr>
      <td style="padding:4px 8px;vertical-align:top;width:38%;color:#111;word-break:break-word;overflow-wrap:anywhere;white-space:pre-line;line-height:1.35;">রিমার্ক/নোট:</td>
