# =====================================================================
# MK Baliadanga — environment template
# Copy to .env and fill in. install.sh generates a populated .env for you.
# =====================================================================

# ---- domains ----
DOMAIN=mohammadkhani.com
API_URL=https://api.mohammadkhani.com
WEB_URL=https://mohammadkhani.com
FILES_URL=https://files.mohammadkhani.com

# ---- postgres ----
PG_USER=mkapp
PG_PASSWORD=changeme
PG_DB=mkapp
DATABASE_URL=postgresql://mkapp:changeme@postgres:5432/mkapp?schema=public

# ---- redis ----
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@redis:6379

# ---- minio ----
MINIO_ROOT_USER=mkadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# ---- auth ----
JWT_SECRET=changeme-32-bytes-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
SESSION_SECRET=changeme-32-bytes-hex

# ---- sms (pluggable) ----
SMS_PROVIDER=greenweb
GREENWEB_TOKEN=
SSL_WIRELESS_TOKEN=
BULKSMSBD_TOKEN=

# ---- runtime ----
NODE_ENV=production
PORT=3000
