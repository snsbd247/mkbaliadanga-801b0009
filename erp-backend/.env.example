APP_NAME="Mohammadkhani ERP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka
APP_URL=https://mohammadkhani.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Database (MySQL 8) ───────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mohammadkhani
DB_USERNAME=mkb_user
DB_PASSWORD=

# ── Sanctum / CORS ───────────────────────────────────────────────────
# SPA + token auth. Stateful domains = frontend origins that send cookies.
SANCTUM_STATEFUL_DOMAINS=mohammadkhani.com,www.mohammadkhani.com,localhost,localhost:8080,127.0.0.1:8080
SESSION_DOMAIN=.mohammadkhani.com
# Comma separated list of allowed frontend origins for CORS.
CORS_ALLOWED_ORIGINS=https://mohammadkhani.com,https://www.mohammadkhani.com,http://localhost:8080

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Super Admin bootstrap (used by AdminUserSeeder) ──────────────────
SUPERADMIN_NAME="Super Admin"
SUPERADMIN_USERNAME=ismail162
SUPERADMIN_EMAIL=admin@mohammadkhani.com
SUPERADMIN_PASSWORD=Admin@123

# ── Mail (optional) ──────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@mohammadkhani.com"
MAIL_FROM_NAME="${APP_NAME}"
