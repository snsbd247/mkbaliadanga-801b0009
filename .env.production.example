# =====================================================================
# Production VPS environment (Self-Hosted Supabase)
# Copy to .env.production and fill from deploy/.env.production (generated
# by deploy/install.sh). The build bakes these into the static bundle.
# Switch Cloud -> Self-Hosted by changing ONLY these values — no code edits.
# =====================================================================
VITE_SUPABASE_URL="https://supabase.mohammadkhani.com"
VITE_SUPABASE_PUBLISHABLE_KEY="<self-hosted-anon-key>"
VITE_SUPABASE_PROJECT_ID="self-hosted"
